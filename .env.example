# FLUKE 8846A控制应用 - 环境变量配置示例

# 应用配置
APP_NAME=FLUKE 8846A Control
APP_VERSION=0.1.0
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# 默认设备配置
DEFAULT_GPIB_ADDRESS=22
DEFAULT_USB_VENDOR_ID=0x1234
DEFAULT_USB_PRODUCT_ID=0x5678
# 串口配置 - 根据操作系统修改
# Windows: COM1, COM2, COM3...
# Linux: /dev/ttyS0, /dev/ttyUSB0, /dev/ttyACM0...
# macOS: /dev/tty.usbserial, /dev/tty.usbmodem...
DEFAULT_SERIAL_PORT=COM3  # 根据您的操作系统修改
DEFAULT_SERIAL_BAUDRATE=9600

# 测量配置
DEFAULT_MEASUREMENT_INTERVAL=1.0  # 秒
DEFAULT_SAMPLE_COUNT=10
DEFAULT_TIMEOUT=5000  # 毫秒

# 数据记录
DATA_LOG_ENABLED=true
DATA_LOG_DIR=./data/measurements
LOG_FORMAT=csv  # csv, json, excel

# GUI配置
THEME=light  # light, dark
LANGUAGE=zh_CN  # zh_CN, en_US
WINDOW_WIDTH=1200
WINDOW_HEIGHT=800

# 复制此文件为 .env 并修改相应值
# cp .env.example .env